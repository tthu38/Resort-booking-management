@{
    ViewData["Title"] = "Dashboard";
    Layout = "_AdminLayout";
    var recentBookings = ViewBag.RecentBookings as List<ResortBookingMVC.Models.Booking> ?? new();
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />
}

<div class="dash-wrap">

    <!-- ══ LEFT ══ -->
    <div class="dash-left">

        <!-- Stats -->
        <div class="dash-stats">
            <div class="dstat dstat-teal">
                <div class="dstat-top">
                    <span class="dstat-label">Resorts</span>
                    <span class="dstat-badge">System</span>
                </div>
                <div class="dstat-value">@ViewBag.TotalResorts</div>
                <div class="dstat-sub">Tổng số resort trong hệ thống</div>
            </div>

            <div class="dstat dstat-blue">
                <div class="dstat-top">
                    <span class="dstat-label">Bookings</span>
                    <span class="dstat-badge">Active</span>
                </div>
                <div class="dstat-value">@ViewBag.TotalBookings</div>
                <div class="dstat-sub">Tổng booking đã tạo</div>
            </div>

            <div class="dstat dstat-purple">
                <div class="dstat-top">
                    <span class="dstat-label">Users</span>
                    <span class="dstat-badge">Members</span>
                </div>
                <div class="dstat-value">@ViewBag.TotalUsers</div>
                <div class="dstat-sub">Người dùng đã đăng ký</div>
            </div>
        </div>

        <!-- Revenue + Chart -->
        <div class="dash-card">
            <div class="dash-card-hd" style="margin-bottom:0;">
                <div class="dash-card-title">Doanh thu tuần này</div>
                <a asp-action="Bookings" class="dash-btn-outline">
                    Xem bookings
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.5"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14M12 5l7 7-7 7" />
                    </svg>
                </a>
            </div>
            <div class="dash-revenue-section">
                <div>
                    <div class="dash-revenue">
                        @(((decimal)ViewBag.TotalRevenue).ToString("N0"))đ
                    </div>
                    <div class="dash-revenue-sub">Tổng doanh thu đã ghi nhận</div>
                    <div class="dash-revenue-badge">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2.5"
                             stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="22 7 13.5 15.5 8.5 10.5 2 17" />
                            <polyline points="16 7 22 7 22 13" />
                        </svg>
                        Cập nhật mới nhất
                    </div>
                </div>
            </div>
            <div class="dash-chart-wrap">
                <svg class="dash-bars-svg" viewBox="0 0 700 200" style="overflow:visible;">
                    <!-- Grid lines -->
                    <line x1="30" y1="20" x2="690" y2="20" stroke="#f1f5f9" stroke-width="1" />
                    <line x1="30" y1="55" x2="690" y2="55" stroke="#f1f5f9" stroke-width="1" />
                    <line x1="30" y1="90" x2="690" y2="90" stroke="#f1f5f9" stroke-width="1" />
                    <line x1="30" y1="125" x2="690" y2="125" stroke="#f1f5f9" stroke-width="1" />
                    <line x1="30" y1="160" x2="690" y2="160" stroke="#e2e8f0" stroke-width="1" />
                    <!-- Y labels -->
                    <text x="20" y="164" text-anchor="end" font-size="11" fill="#cbd5e1">0</text>
                    <text x="20" y="129" text-anchor="end" font-size="11" fill="#cbd5e1">25%</text>
                    <text x="20" y="94" text-anchor="end" font-size="11" fill="#cbd5e1">50%</text>
                    <text x="20" y="59" text-anchor="end" font-size="11" fill="#cbd5e1">75%</text>
                    <text x="20" y="24" text-anchor="end" font-size="11" fill="#cbd5e1">100%</text>
                    <!-- Bars: x đều nhau, width nhỏ gọn -->
                    <rect x="60" y="90" width="48" height="70" rx="5" fill="rgb(45,212,191)" opacity="0.75" />
                    <rect x="155" y="110" width="48" height="50" rx="5" fill="rgb(45,212,191)" opacity="0.75" />
                    <rect x="250" y="50" width="48" height="110" rx="5" fill="rgb(45,212,191)" />
                    <rect x="345" y="80" width="48" height="80" rx="5" fill="rgb(45,212,191)" opacity="0.75" />
                    <rect x="440" y="125" width="48" height="35" rx="5" fill="rgb(45,212,191)" opacity="0.6" />
                    <rect x="535" y="60" width="48" height="100" rx="5" fill="rgb(45,212,191)" />
                    <rect x="630" y="90" width="48" height="70" rx="5" fill="rgb(45,212,191)" opacity="0.75" />
                    <!-- Day labels — cách bar 10px -->
                    <text x="84" y="185" text-anchor="middle" font-size="10" fill="#94a3b8">Sat</text>
                    <text x="179" y="185" text-anchor="middle" font-size="10" fill="#94a3b8">Sun</text>
                    <text x="274" y="185" text-anchor="middle" font-size="10" fill="#94a3b8">Mon</text>
                    <text x="369" y="185" text-anchor="middle" font-size="10" fill="#94a3b8">Tue</text>
                    <text x="464" y="185" text-anchor="middle" font-size="10" fill="#94a3b8">Wed</text>
                    <text x="559" y="185" text-anchor="middle" font-size="10" fill="#94a3b8">Thu</text>
                    <text x="654" y="185" text-anchor="middle" font-size="10" fill="#94a3b8">Fri</text>
                </svg>
            </div>
        </div>

        <!-- Recent Bookings -->
        <div class="dash-card">
            <div class="dash-card-hd">
                <div class="dash-card-title">Booking gần đây</div>
                <a asp-action="Bookings" class="dash-btn-outline">
                    Xem tất cả
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.5"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14M12 5l7 7-7 7" />
                    </svg>
                </a>
            </div>
            <table class="dash-table">
                <thead>
                    <tr>
                        <th>Booking</th>
                        <th>Khách</th>
                        <th>Resort</th>
                        <th>Check-in</th>
                        <th>Trạng thái</th>
                        <th>Tổng tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in recentBookings)
                    {
                        string statusClass = b.Status.ToString().ToLower() switch
                        {
                            "pending" => "ds-pending",
                            "confirmed" => "ds-confirmed",
                            "cancelled" => "ds-cancelled",
                            _ => "ds-default"
                        };
                        string statusLabel = b.Status.ToString() switch
                        {
                            "Pending" => "Chờ xác nhận",
                            "Confirmed" => "Đã xác nhận",
                            "Cancelled" => "Đã hủy",
                            "Completed" => "Hoàn thành",
                            "CheckedIn" => "Đã check-in",
                            "Rejected" => "Từ chối",
                            _ => b.Status.ToString()
                        };
                        <tr>
                            <td><span class="dash-code">#@b.BookingCode</span></td>
                            <td>
                                @b.User?.FullName
                                <small>@b.User?.Email</small>
                            </td>
                            <td>@b.Resort?.Name</td>
                            <td>@b.CheckInDate.ToString("dd/MM/yyyy")</td>
                            <td><span class="dash-status @statusClass">@statusLabel</span></td>
                            <td style="font-weight:600;">@b.TotalAmount.ToString("N0")đ</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>

    <!-- ══ RIGHT ══ -->
    <div class="dash-right">

        <!-- Promo card -->
        <div class="dash-promo-card">
            <div>
                <div class="dash-promo-num">@ViewBag.TotalBookings</div>
                <div class="dash-promo-label">Tổng Bookings</div>
                <a asp-action="Bookings" class="dash-promo-btn">
                    Xem chi tiết
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.5"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14M12 5l7 7-7 7" />
                    </svg>
                </a>
            </div>
            <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=300&q=80"
                 class="dash-promo-img" alt="resort" />
        </div>

        <!-- Summary -->
        <div class="dash-card">
            <div class="dash-card-hd">
                <div class="dash-card-title">Tổng quan hệ thống</div>
            </div>

            <div class="dash-avail">
                <span class="dash-avail-label">Tổng doanh thu</span>
                <span class="dash-avail-total">
                    @((((decimal)ViewBag.TotalRevenue) / 1_000_000).ToString("N1"))M
                </span>
            </div>

            <div class="dash-room-row">
                <div class="dash-room-label">Resorts</div>
                <div class="dash-room-bar-wrap">
                    <div class="dash-room-bar" style="width:90%;background:rgb(45,212,191);"></div>
                </div>
                <div class="dash-room-pct">@ViewBag.TotalResorts</div>
            </div>

            <div class="dash-room-row">
                <div class="dash-room-label">Bookings</div>
                <div class="dash-room-bar-wrap">
                    <div class="dash-room-bar" style="width:75%;background:#60a5fa;"></div>
                </div>
                <div class="dash-room-pct">@ViewBag.TotalBookings</div>
            </div>

            <div class="dash-room-row">
                <div class="dash-room-label">Users</div>
                <div class="dash-room-bar-wrap">
                    <div class="dash-room-bar" style="width:60%;background:#a78bfa;"></div>
                </div>
                <div class="dash-room-pct">@ViewBag.TotalUsers</div>
            </div>
        </div>

    </div>

</div>
