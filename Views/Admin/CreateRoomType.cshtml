@model ResortBookingMVC.Models.RoomType
@{
    ViewData["Title"] = "Thêm loại phòng";
    Layout = "_AdminLayout";
    ViewData["HeaderSection"] = "Quản lý Loại phòng";
    ViewData["HeaderTitle"] = "Thêm loại phòng mới";
    ViewData["HeaderBtnUrl"] = Url.Action("RoomTypes", new { resortId = Model.ResortId });
    ViewData["HeaderBtnLabel"] = "Quay lại";
    ViewData["HeaderBtnIcon"] = "back";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />
}

<partial name="_AdminPageHeader" />

<div class="af-card">
    <form asp-action="CreateRoomType" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ResortId" />
        <div asp-validation-summary="ModelOnly" class="af-validation"></div>

        <!-- Section: Thông tin cơ bản -->
        <div class="af-section-title">Thông tin cơ bản</div>

        <div class="af-field">
            <label>Tên loại phòng <span class="af-required">*</span></label>
            <input asp-for="Name" placeholder="VD: Deluxe Ocean View" />
        </div>

        <div class="af-field">
            <label>Mô tả</label>
            <textarea asp-for="Description" rows="3" placeholder="Mô tả ngắn về loại phòng..."></textarea>
        </div>

        <div class="af-grid-2">
            <div class="af-field">
                <label>Loại giường</label>
                <input asp-for="BedType" placeholder="VD: Giường King" />
            </div>
            <div class="af-field">
                <label>Diện tích (m²)</label>
                <input asp-for="AreaSqm" type="number" step="0.5" placeholder="VD: 45" />
            </div>
        </div>

        <div class="af-grid-2">
            <div class="af-field">
                <label>Người lớn tối đa <span class="af-required">*</span></label>
                <input asp-for="MaxAdults" type="number" min="1" max="10" />
            </div>
            <div class="af-field">
                <label>Trẻ em tối đa</label>
                <input asp-for="MaxChildren" type="number" min="0" max="5" />
            </div>
        </div>

        <!-- Section: Giá & Đặt cọc -->
        <div class="af-section-title" style="margin-top:1.5rem;">Giá & Đặt cọc</div>

        <div class="af-grid-2">
            <div class="af-field">
                <label>Giá cơ bản / đêm (VNĐ) <span class="af-required">*</span></label>
                <input asp-for="BasePricePerNight" type="number" min="0" placeholder="VD: 2000000" />
                <span class="af-hint">Nhập số tiền không có dấu chấm hay phẩy</span>
            </div>
            <div class="af-field">
                <label>Phần trăm đặt cọc (%)</label>
                <input asp-for="DepositPercentage" type="number" min="0" max="100" step="5" />
                <span class="af-hint">Mặc định 30% — khách cần trả trước khi xác nhận</span>
            </div>
        </div>

        <!-- Actions -->
        <div class="af-actions">
            <button type="submit" class="af-btn-save">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2.5"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z" />
                    <polyline points="17 21 17 13 7 13 7 21" />
                    <polyline points="7 3 7 8 15 8" />
                </svg>
                Lưu loại phòng
            </button>
            <a asp-action="RoomTypes" asp-route-resortId="@Model.ResortId" class="af-btn-cancel">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScripts" />
}
