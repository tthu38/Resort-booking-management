@model ResortBookingMVC.Models.RoomType
@{
    ViewData["Title"] = "Thêm loại phòng";
    Layout = "_AdminLayout";
}

<div class="admin-page-header">
    <h2 class="admin-page-title">➕ Thêm loại phòng</h2>
    <a asp-action="RoomTypes" asp-route-resortId="@Model.ResortId" class="btn btn-outline">← Quay lại</a>
</div>

<div class="admin-card" style="max-width:680px">
    <form asp-action="CreateRoomType" method="post" style="padding:24px;">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ResortId" />
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="form-group">
            <label>Tên loại phòng *</label>
            <input asp-for="Name" class="form-control" placeholder="VD: Deluxe Ocean View" />
        </div>

        <div class="form-group">
            <label>Mô tả</label>
            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Mô tả ngắn về loại phòng..."></textarea>
        </div>

        <div class="form-inline-2">
            <div class="form-group">
                <label>Người lớn tối đa *</label>
                <input asp-for="MaxAdults" type="number" min="1" max="10" class="form-control" />
            </div>
            <div class="form-group">
                <label>Trẻ em tối đa</label>
                <input asp-for="MaxChildren" type="number" min="0" max="5" class="form-control" />
            </div>
        </div>

        <div class="form-inline-2">
            <div class="form-group">
                <label>Diện tích (m²)</label>
                <input asp-for="AreaSqm" type="number" step="0.5" class="form-control" placeholder="VD: 45" />
            </div>
            <div class="form-group">
                <label>Loại giường</label>
                <input asp-for="BedType" class="form-control" placeholder="VD: Giường King" />
            </div>
        </div>

        <div class="form-inline-2">
            <div class="form-group">
                <label>Giá cơ bản/đêm (VNĐ) *</label>
                <input asp-for="BasePricePerNight" type="number" min="0" class="form-control" placeholder="VD: 2000000" />
            </div>
            <div class="form-group">
                <label>Phần trăm đặt cọc (%)</label>
                <input asp-for="DepositPercentage" type="number" min="0" max="100" step="5" class="form-control" />
            </div>
        </div>

        <button type="submit" class="btn btn-primary">💾 Lưu loại phòng</button>
    </form>
</div>

@section Scripts { <partial name="_ValidationScripts" /> }
