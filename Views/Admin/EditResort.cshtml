@model ResortBookingMVC.Models.Resort
@{
    ViewData["Title"] = "Chỉnh sửa Resort";
    Layout = "_AdminLayout";
}

<div class="admin-page-header">
    <h2 class="admin-page-title">✏️ Chỉnh sửa Resort</h2>
    <a asp-action="Resorts" class="btn btn-outline">← Quay lại</a>
</div>

<div class="admin-card" style="max-width:700px">
    <form asp-action="EditResort" method="post" style="padding:24px;">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="form-group">
            <label>Tên resort *</label>
            <input asp-for="Name" class="form-control" />
        </div>

        <div class="form-group">
            <label>Địa điểm *</label>
            <select asp-for="LocationId" class="form-control">
                @foreach (var loc in ViewBag.Locations as List<ResortBookingMVC.Models.Location> ?? new())
                {
                    <option value="@loc.Id" selected="@(Model.LocationId == loc.Id ? "selected" : null)">
                        @loc.Province @(loc.District != null ? "- " + loc.District : "")
                    </option>
                }
            </select>
        </div>

        <div class="form-group">
            <label>Địa chỉ chi tiết</label>
            <input asp-for="Address" class="form-control" />
        </div>

        <div class="form-group">
            <label>Mô tả</label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        </div>

        <div class="form-inline-2">
            <div class="form-group">
                <label>Số sao (1–5)</label>
                <input asp-for="StarRating" type="number" min="1" max="5" class="form-control" />
            </div>
            <div class="form-group">
                <label>URL Ảnh đại diện</label>
                <input asp-for="ThumbnailUrl" class="form-control" placeholder="https://..." />
            </div>
        </div>

        <div class="form-inline-2">
            <div class="form-group">
                <label>Giờ check-in</label>
                <input asp-for="CheckInTime" type="time" class="form-control" />
            </div>
            <div class="form-group">
                <label>Giờ check-out</label>
                <input asp-for="CheckOutTime" type="time" class="form-control" />
            </div>
        </div>

        <div class="form-group">
            <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
                <input asp-for="IsActive" type="checkbox" />
                Hiển thị (Active)
            </label>
        </div>

        <button type="submit" class="btn btn-primary">💾 Lưu thay đổi</button>
    </form>
</div>

@section Scripts { <partial name="_ValidationScripts" /> }
