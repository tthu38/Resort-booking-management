@model ResortBookingMVC.Models.Resort
@{
    ViewData["Title"] = "Chỉnh sửa Resort";
    Layout = "_AdminLayout";
    ViewData["HeaderSection"] = "Quản lý Resort";
    ViewData["HeaderTitle"] = "Chỉnh sửa Resort";
    ViewData["HeaderBtnUrl"] = Url.Action("Resorts");
    ViewData["HeaderBtnLabel"] = "Quay lại";
    ViewData["HeaderBtnIcon"] = "back";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />
}

<partial name="_AdminPageHeader" />

<div class="af-card">
    <form asp-action="EditResort" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="af-validation"></div>

        <!-- Section: Thông tin cơ bản -->
        <div class="af-section-title">Thông tin cơ bản</div>

        <div class="af-field">
            <label>Tên resort <span class="af-required">*</span></label>
            <input asp-for="Name" placeholder="VD: Vinpearl Da Nang" />
        </div>

        <div class="af-grid-2">
            <div class="af-field">
                <label>Địa điểm <span class="af-required">*</span></label>
                <select asp-for="LocationId">
                    @foreach (var loc in ViewBag.Locations as List<ResortBookingMVC.Models.Location> ?? new())
                    {
                        <option value="@loc.Id" selected="@(Model.LocationId == loc.Id ? "selected" : null)">
                            @loc.Province @(loc.District != null ? "— " + loc.District : "")
                        </option>
                    }
                </select>
            </div>
            <div class="af-field">
                <label>Số sao</label>
                <input asp-for="StarRating" type="number" min="1" max="5" placeholder="1 – 5" />
            </div>
        </div>

        <div class="af-field">
            <label>Địa chỉ chi tiết</label>
            <input asp-for="Address" placeholder="Số nhà, đường, phường..." />
        </div>

        <div class="af-field">
            <label>Mô tả</label>
            <textarea asp-for="Description" rows="4" placeholder="Mô tả tổng quan về resort..."></textarea>
        </div>

        <!-- Section: Hình ảnh & Thời gian -->
        <div class="af-section-title" style="margin-top:1.5rem;">Hình ảnh & Thời gian</div>

        <div class="af-field">
            <label>URL ảnh đại diện</label>
            <input asp-for="ThumbnailUrl" placeholder="https://..." />
            <span class="af-hint">Dán link ảnh trực tiếp từ Unsplash hoặc server của bạn</span>
        </div>

        <div class="af-grid-2">
            <div class="af-field">
                <label>Giờ nhận phòng</label>
                <input asp-for="CheckInTime" type="time" />
            </div>
            <div class="af-field">
                <label>Giờ trả phòng</label>
                <input asp-for="CheckOutTime" type="time" />
            </div>
        </div>

        <!-- Section: Trạng thái -->
        <div class="af-section-title" style="margin-top:1.5rem;">Trạng thái</div>

        <label class="af-toggle">
            <input asp-for="IsActive" type="checkbox" />
            <div class="af-toggle-track">
                <div class="af-toggle-thumb"></div>
            </div>
            <span>Hiển thị resort này cho khách hàng</span>
        </label>

        <!-- Actions -->
        <div class="af-actions">
            <button type="submit" class="af-btn-save">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2.5"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z" />
                    <polyline points="17 21 17 13 7 13 7 21" />
                    <polyline points="7 3 7 8 15 8" />
                </svg>
                Lưu thay đổi
            </button>
            <a asp-action="Resorts" class="af-btn-cancel">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScripts" />
}
