@{
    ViewData["Title"] = "Liên hệ";
}

@section Styles {
    <link rel="stylesheet" href="~/css/contact.css" asp-append-version="true" />
}

<div class="contact-page">

    <!-- Hero -->
    <div class="contact-hero">
        <img src="https://images.unsplash.com/photo-1540541338287-41700207dee6?w=1400&q=85&auto=format&fit=crop"
             alt="Resort contact" class="contact-hero-img" />
        <div class="contact-hero-overlay"></div>
        <div class="contact-hero-content">
            <p class="contact-eyebrow">Liên hệ</p>
            <h1>Chúng tôi luôn sẵn sàng<br>lắng nghe bạn</h1>
        </div>
    </div>

    <div class="contact-wrap">
        <div class="contact-grid">

            <!-- LEFT: thông tin -->
            <div class="contact-info">
                <div class="info-card-title">Thông tin liên hệ</div>

                <div class="info-item">
                    <div class="info-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                             stroke="rgb(45,212,191)" stroke-width="1.8"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.12 1.18 2 2 0 012.1 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92v2z" />
                        </svg>
                    </div>
                    <div>
                        <div class="info-label">Hotline</div>
                        <div class="info-value">1900 xxxx</div>
                        <div class="info-sub">8:00 – 22:00 mỗi ngày</div>
                    </div>
                </div>

                <div class="info-item">
                    <div class="info-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                             stroke="rgb(45,212,191)" stroke-width="1.8"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                            <polyline points="22,6 12,13 2,6" />
                        </svg>
                    </div>
                    <div>
                        <div class="info-label">Email</div>
                        <div class="info-value">support@resortbooking.vn</div>
                        <div class="info-sub">Phản hồi trong 24 giờ</div>
                    </div>
                </div>

                <div class="info-item">
                    <div class="info-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                             stroke="rgb(45,212,191)" stroke-width="1.8"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 21s-8-7.3-8-12a8 8 0 0116 0c0 4.7-8 12-8 12z" />
                            <circle cx="12" cy="9" r="2.5" />
                        </svg>
                    </div>
                    <div>
                        <div class="info-label">Địa chỉ</div>
                        <div class="info-value">123 Nguyễn Huệ, Q.1</div>
                        <div class="info-sub">TP. Hồ Chí Minh</div>
                    </div>
                </div>

                <!-- Wave decoration -->
                <div class="contact-wave">
                    <svg width="100%" height="40" viewBox="0 0 300 40" preserveAspectRatio="none"
                         fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M0 20 Q37.5 0 75 20 Q112.5 40 150 20 Q187.5 0 225 20 Q262.5 40 300 20"
                              stroke="rgba(45,212,191,0.3)" stroke-width="2" fill="none" />
                        <path d="M0 30 Q37.5 10 75 30 Q112.5 50 150 30 Q187.5 10 225 30 Q262.5 50 300 30"
                              stroke="rgba(45,212,191,0.15)" stroke-width="2" fill="none" />
                    </svg>
                </div>
            </div>

            <!-- RIGHT: form -->
            <div class="contact-form-card">
                <div class="info-card-title">Gửi tin nhắn</div>

                <form>
                    <div class="cf-field">
                        <label>Họ và tên</label>
                        <input type="text" placeholder="Nguyễn Văn A" />
                    </div>
                    <div class="cf-field">
                        <label>Email</label>
                        <input type="email" placeholder="your@email.com" />
                    </div>
                    <div class="cf-field">
                        <label>Nội dung</label>
                        <textarea rows="4" placeholder="Nội dung cần hỗ trợ..."></textarea>
                    </div>
                    <button type="submit" class="btn-send">
                        Gửi tin nhắn
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2.5"
                             stroke-linecap="round" stroke-linejoin="round">
                            <line x1="22" y1="2" x2="11" y2="13" />
                            <polygon points="22 2 15 22 11 13 2 9 22 2" />
                        </svg>
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>
