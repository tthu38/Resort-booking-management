@model LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

@section Styles {
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
}

<div class="auth-page">

    <!-- Background ảnh full màn hình -->
    <div class="auth-bg">
        <img src="https://images.unsplash.com/photo-1520250497591-112f2f40a3f4?w=1920&q=90&auto=format&fit=crop"
             alt="Beach resort" />
        <div class="auth-bg-overlay"></div>
    </div>

    <!-- Form nổi giữa màn hình -->
    <div class="auth-card">

        <div class="auth-logo">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                <path d="M2 14 Q6 4 11 9 Q16 14 20 7"
                      stroke="rgb(45,212,191)" stroke-width="2.2" stroke-linecap="round" fill="none" />
                <circle cx="11" cy="18" r="2.8" fill="rgb(45,212,191)" />
            </svg>
        </div>

        <h2>Đăng nhập</h2>
        <p class="auth-subtitle">Chào mừng bạn quay trở lại!</p>

        <!-- Google -->
        <a asp-action="LoginWithGoogle" asp-controller="Auth" class="btn-google">
            <svg width="18" height="18" viewBox="0 0 18 18">
                <path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.874 2.684-6.615z" fill="#4285F4" />
                <path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z" fill="#34A853" />
                <path d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332z" fill="#FBBC05" />
                <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58z" fill="#EA4335" />
            </svg>
            Tiếp tục với Google
        </a>

        <div class="divider">HOẶC</div>

        <form asp-action="Login" asp-route-returnUrl="@ViewBag.ReturnUrl" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="Email">Email</label>
                <input asp-for="Email" type="email"
                       placeholder="your@email.com" autocomplete="email" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password">Mật khẩu</label>
                <div class="input-password">
                    <input asp-for="Password" type="password"
                           placeholder="••••••••" autocomplete="current-password"
                           id="passwordInput" />
                    <button type="button" class="toggle-pw"
                            onclick="togglePassword()"
                            aria-label="Hiện/ẩn mật khẩu">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <!-- Ghi nhớ + Quên mật khẩu cùng hàng -->
            <div class="form-check">
                <div class="form-check-left">
                    <input asp-for="RememberMe" type="checkbox" />
                    <label asp-for="RememberMe">Ghi nhớ đăng nhập</label>
                </div>
                <a asp-action="ForgotPassword" class="forgot-link">Quên mật khẩu?</a>
            </div>

            <button type="submit" class="btn-primary-full">Đăng nhập</button>
        </form>

        <p class="auth-switch">
            Chưa có tài khoản?
            <a asp-action="Register">Đăng ký ngay</a>
        </p>
    </div>

    <!-- Brand watermark -->
    <div class="auth-brand">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M1 11 Q4.5 2 8 7 Q11.5 12 15 5" stroke="rgba(255,255,255,0.8)"
                  stroke-width="2" stroke-linecap="round" fill="none" />
            <circle cx="8" cy="13.5" r="1.8" fill="rgb(45,212,191)" />
        </svg>
        HolidayBooking
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScripts" />
    <script>
        function togglePassword() {
            const el = document.getElementById('passwordInput');
            el.type = el.type === 'password' ? 'text' : 'password';
        }
    </script>
}
