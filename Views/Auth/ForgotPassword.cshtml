@model ResortBookingMVC.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
}

@section Styles {
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/forgot-password.css" asp-append-version="true" />
}

<div class="auth-page">
    <div class="auth-bg">
        <img src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=1920&q=90&auto=format&fit=crop" alt="Beach resort" />
        <div class="auth-bg-overlay"></div>
    </div>

    <div class="auth-card">
        <div class="auth-logo">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
                 stroke="rgb(45,212,191)" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                <path d="M7 11V7a5 5 0 0110 0v4" />
            </svg>
        </div>

        <h2>Quên mật khẩu</h2>
        <p class="auth-subtitle">Nhập email để nhận mã OTP 6 chữ số</p>

        <form asp-action="ForgotPassword" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="Email">Email</label>
                <input asp-for="Email" type="email"
                       placeholder="your@email.com" autocomplete="email" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <button type="submit" class="btn-primary-full">Gửi mã OTP</button>
        </form>

        <p class="auth-switch">
            Nhớ mật khẩu rồi?
            <a asp-action="Login">Đăng nhập</a>
        </p>
    </div>

    <div class="auth-brand">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
            <path d="M1 11 Q4.5 2 8 7 Q11.5 12 15 5" stroke="rgba(255,255,255,0.8)" stroke-width="2" stroke-linecap="round" fill="none" />
            <circle cx="8" cy="13.5" r="1.8" fill="rgb(45,212,191)" />
        </svg>
        HolidayBooking
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScripts" />
}
