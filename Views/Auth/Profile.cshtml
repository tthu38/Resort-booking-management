@model ResortBookingMVC.Models.User
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    var initial = Model.FullName?.Length > 0 ? Model.FullName[0].ToString().ToUpper() : "U";
}

@section Styles {
    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />
}

<div class="profile-page">
    <div class="profile-wrap">

        <!-- Top bar -->
        <div class="profile-topbar">
            <div class="profile-avatar">@initial</div>
            <div class="profile-topbar-info">
                <h1>@Model.FullName</h1>
                <p>@Model.Email</p>
            </div>
            <a asp-action="EditProfile" class="btn-edit-profile">Cập nhật hồ sơ</a>
        </div>

        <!-- Thông tin cá nhân -->
        <div class="profile-card">
            <div class="profile-card-title">Thông tin cá nhân</div>
            <div class="profile-grid">
                <div class="pf-item">
                    <label>Họ và tên</label>
                    <div class="pf-value">@Model.FullName</div>
                </div>
                <div class="pf-item">
                    <label>Số điện thoại</label>
                    <div class="pf-value @(string.IsNullOrEmpty(Model.PhoneNumber) ? "empty" : "")">
                        @(string.IsNullOrEmpty(Model.PhoneNumber) ? "Chưa cập nhật" : Model.PhoneNumber)
                    </div>
                </div>
                <div class="pf-item">
                    <label>Trạng thái</label>
                    <div class="pf-value">
                        <span class="role-badge" style="background:rgba(34,197,94,0.1);color:rgb(22,163,74);border-color:rgba(34,197,94,0.25);">
                            Đang hoạt động
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Email -->
        <div class="profile-card">
            <div class="profile-card-title">Địa chỉ Email</div>
            <div class="email-row">
                <div class="email-icon">
                    <svg width="16" height="16" viewBox="0 0 20 20" fill="none">
                        <path d="M2 5a2 2 0 012-2h12a2 2 0 012 2v10a2 2 0 01-2 2H4a2 2 0 01-2-2V5z"
                              stroke="rgb(45,212,191)" stroke-width="1.5" fill="none" />
                        <path d="M2 5l8 6 8-6" stroke="rgb(45,212,191)" stroke-width="1.5" stroke-linecap="round" />
                    </svg>
                </div>
                <div>
                    <div class="email-addr">@Model.Email</div>
                    <div class="email-since">Thành viên từ @Model.CreatedAt.ToString("dd/MM/yyyy")</div>
                </div>
            </div>
        </div>

        <!-- Quick action -->
        <div class="profile-card" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
            <div>
                <div style="font-size:0.9rem;font-weight:600;color:#0f172a;">Lịch sử đặt phòng</div>
                <div style="font-size:0.8rem;color:#64748b;">Xem tất cả booking của bạn</div>
            </div>
            <a asp-controller="Booking" asp-action="MyBookings" class="btn-my-bookings">
                Xem Booking của tôi
            </a>
        </div>

    </div>
</div>
