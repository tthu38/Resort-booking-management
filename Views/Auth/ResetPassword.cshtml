@model ResortBookingMVC.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

@section Styles {
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/forgotPassword.css" asp-append-version="true" />
}

<div class="auth-page">
    <div class="auth-bg">
        <img src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=1920&q=90&auto=format&fit=crop" alt="Beach resort" />
        <div class="auth-bg-overlay"></div>
    </div>

    <div class="auth-card">
        <div class="auth-logo">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
                 stroke="rgb(45,212,191)" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
            </svg>
        </div>

        <!-- Step indicator -->
        <div class="fp-steps">
            <div class="fp-step done">
                <div class="fp-step-circle"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg></div>
                <div class="fp-step-label">Email</div>
            </div>
            <div class="fp-step-line done"></div>
            <div class="fp-step done">
                <div class="fp-step-circle"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg></div>
                <div class="fp-step-label">OTP</div>
            </div>
            <div class="fp-step-line done"></div>
            <div class="fp-step active">
                <div class="fp-step-circle">3</div>
                <div class="fp-step-label">Mật khẩu</div>
            </div>
        </div>

        <h2>Đặt lại mật khẩu</h2>
        <p class="auth-subtitle">
            Tài khoản: <span class="fp-email-highlight">@Model.Email</span>
        </p>

        <form asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Token" />
            <input type="hidden" asp-for="Email" />
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="NewPassword">Mật khẩu mới</label>
                <div class="input-password">
                    <input asp-for="NewPassword" type="password"
                           placeholder="Tối thiểu 6 ký tự"
                           autocomplete="new-password" id="newPw" />
                    <button type="button" class="toggle-pw"
                            onclick="togglePw('newPw', this)">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                    </button>
                </div>
                <span class="fp-pw-hint">Tối thiểu 6 ký tự</span>
                <span asp-validation-for="NewPassword" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword">Xác nhận mật khẩu mới</label>
                <div class="input-password">
                    <input asp-for="ConfirmPassword" type="password"
                           placeholder="Nhập lại mật khẩu mới"
                           autocomplete="new-password" id="confirmPw" />
                    <button type="button" class="toggle-pw"
                            onclick="togglePw('confirmPw', this)">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
            </div>

            <button type="submit" class="btn-primary-full">Đặt lại mật khẩu</button>
        </form>
    </div>

    <div class="auth-brand">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
            <path d="M1 11 Q4.5 2 8 7 Q11.5 12 15 5" stroke="rgba(255,255,255,0.8)" stroke-width="2" stroke-linecap="round" fill="none" />
            <circle cx="8" cy="13.5" r="1.8" fill="rgb(45,212,191)" />
        </svg>
        HolidayBooking
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScripts" />
    <script>
        function togglePw(inputId, btn) {
            const el = document.getElementById(inputId);
            const isHidden = el.type === 'password';
            el.type = isHidden ? 'text' : 'password';
            btn.style.color = isHidden ? 'rgb(45,212,191)' : '#9ca3af';
        }
    </script>
}
