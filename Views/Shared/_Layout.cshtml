<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Nunito:wght@600;700;800&display=swap" rel="stylesheet" />
    <title>@ViewData["Title"] - HolidayBooking</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Index" && ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "home-page" : "")">

    @{
        bool isHome = ViewContext.RouteData.Values["controller"]?.ToString() == "Home"
        && ViewContext.RouteData.Values["action"]?.ToString() == "Index";
    }

    <nav class="navbar @(isHome ? "navbar-transparent" : "navbar-solid")">
        <div class="nav-container">
            <a class="nav-brand" asp-controller="Home" asp-action="Index">
                Holiday<span>booking</span>
            </a>
            <div class="nav-links">
                <a asp-controller="Home" asp-action="Index">Trang chủ</a>
                <a asp-controller="Resort" asp-action="Search">Resort</a>
                <a asp-controller="Home" asp-action="About">Giới thiệu</a>
                <a asp-controller="Home" asp-action="Contact">Liên hệ</a>
            </div>
            <div class="nav-actions">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    if (User.IsInRole("ADMIN") || User.IsInRole("STAFF"))
                    {
                        <a asp-controller="Admin" asp-action="Index" class="nav-link-plain">Quản trị</a>
                    }
                    <a asp-controller="Booking" asp-action="MyBookings" class="nav-link-plain">Booking của tôi</a>
                    <div class="nav-user">
                        <button class="nav-avatar-btn">@User.Identity.Name[0]</button>
                        <div class="nav-dropdown">
                            <a asp-controller="Auth" asp-action="Profile">Hồ sơ</a>
                            <a asp-controller="Booking" asp-action="MyBookings">Booking của tôi</a>
                            <form asp-controller="Auth" asp-action="Logout" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit">Đăng xuất</button>
                            </form>
                        </div>
                    </div>
                }
                else
                {
                    <a asp-controller="Auth" asp-action="Login" class="nav-btn-ghost">Đăng nhập</a>
                    <a asp-controller="Auth" asp-action="Register" class="nav-btn-solid">Đăng ký</a>
                }
            </div>
        </div>
    </nav>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
            <button class="alert-close" onclick="this.parentElement.remove()">×</button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-error">
            @TempData["Error"]
            <button class="alert-close" onclick="this.parentElement.remove()">×</button>
        </div>
    }

    <main class="main-content">
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="footer-container">
            <div class="footer-col">
                <div class="footer-brand">Holiday<span>booking</span></div>
                <p>Nền tảng đặt phòng resort hàng đầu Việt Nam. Giá tốt nhất, trải nghiệm tuyệt vời nhất.</p>
            </div>
            <div class="footer-col">
                <h4>Khám phá</h4>
                <a asp-controller="Resort" asp-action="Search">Tìm resort</a>
                <a asp-controller="Home" asp-action="About">Về chúng tôi</a>
                <a asp-controller="Home" asp-action="Contact">Liên hệ</a>
                <a asp-controller="Home" asp-action="Privacy">Chính sách</a>
            </div>
            <div class="footer-col">
                <h4>Hỗ trợ</h4>
                <p>Hotline: 1900 xxxx</p>
                <p>Email: support@holidaybooking.vn</p>
                <p>Giờ làm việc: 8:00 – 22:00</p>
            </div>
            <div class="footer-col">
                <h4>Thanh toán</h4>
                <div class="payment-logos">
                    <span class="pay-badge">VNPay</span>
                    <span class="pay-badge">MoMo</span>
                    <span class="pay-badge">ZaloPay</span>
                    <span class="pay-badge">Visa</span>
                </div>
            </div>
        </div>
        <div class="footer-bottom">© @DateTime.Now.Year HolidayBooking. All rights reserved.</div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
