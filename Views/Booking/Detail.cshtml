@model ResortBookingMVC.Models.Booking
@using ResortBookingMVC.Models.Enums
@{
    ViewData["Title"] = $"Booking #{Model.BookingCode}";

    string badgeClass = Model.Status switch
    {
        BookingStatus.Pending => "pending",
        BookingStatus.Confirmed => "confirmed",
        BookingStatus.CheckedIn => "checkedin",
        BookingStatus.Completed => "completed",
        BookingStatus.Cancelled => "cancelled",
        BookingStatus.Rejected => "rejected",
        _ => "cancelled"
    };

    string statusLabel = Model.Status switch
    {
        BookingStatus.Pending => "Chờ xác nhận",
        BookingStatus.Confirmed => "Đã xác nhận",
        BookingStatus.CheckedIn => "Đã check-in",
        BookingStatus.Completed => "Hoàn thành",
        BookingStatus.Cancelled => "Đã hủy",
        BookingStatus.Rejected => "Bị từ chối",
        _ => Model.Status.ToString()
    };

    bool isInactive = Model.Status == BookingStatus.Cancelled || Model.Status == BookingStatus.Rejected;
    var remaining = Model.TotalAmount - Model.PaidAmount;
}

@section Styles {
    <link rel="stylesheet" href="~/css/bookingDetail.css" asp-append-version="true" />
}

<div class="bkdetail-page">
    <div class="bkdetail-wrap">

        <!-- Back -->
        <a asp-action="MyBookings" class="bkdetail-back">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 18l-6-6 6-6" />
            </svg>
            Quay lại danh sách booking
        </a>

        <!-- Hero: mã booking + trạng thái -->
        <div class="bkdetail-hero">
            <div class="bkdetail-hero-strip @(isInactive? badgeClass : "")"></div>
            <div class="bkdetail-hero-body">
                <div>
                    <div class="bkdetail-code-label">Mã booking</div>
                    <div class="bkdetail-code">@Model.BookingCode</div>
                </div>
                <span class="bk-badge @badgeClass">@statusLabel</span>
            </div>
        </div>

        <!-- Grid 2 cột: Resort + Thời gian -->
        <div class="bkdetail-grid">

            <!-- Resort info -->
            <div class="bd-card">
                <div class="bd-card-title">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
                        <polyline points="9 22 9 12 15 12 15 22" />
                    </svg>
                    Thông tin Resort
                </div>
                <div class="resort-name">@Model.Resort?.Name</div>
                <div class="resort-addr">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-top:1px;flex-shrink:0;">
                        <path d="M12 21s-8-7.3-8-12a8 8 0 0116 0c0 4.7-8 12-8 12z" />
                        <circle cx="12" cy="9" r="2.5" />
                    </svg>
                    @Model.Resort?.Address — @Model.Resort?.Location?.Province
                </div>
                <div class="checkinout-times">
                    <div class="cot-item">
                        <label>Giờ nhận phòng</label>
                        <span>@Model.Resort?.CheckInTime.ToString("HH:mm")</span>
                    </div>
                    <div class="cot-item">
                        <label>Giờ trả phòng</label>
                        <span>@Model.Resort?.CheckOutTime.ToString("HH:mm")</span>
                    </div>
                </div>
            </div>

            <!-- Thời gian lưu trú -->
            <div class="bd-card">
                <div class="bd-card-title">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="4" width="18" height="18" rx="2" />
                        <path d="M16 2v4M8 2v4M3 10h18" />
                    </svg>
                    Thời gian lưu trú
                </div>
                <div class="dates-grid">
                    <div class="dg-item">
                        <label>Nhận phòng</label>
                        <span>@Model.CheckInDate.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="dg-item">
                        <label>Trả phòng</label>
                        <span>@Model.CheckOutDate.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="dg-item">
                        <label>Số đêm</label>
                        <span>@Model.TotalNights đêm</span>
                    </div>
                    <div class="dg-item">
                        <label>Số phòng</label>
                        <span>@Model.NumRooms phòng</span>
                    </div>
                    <div class="dg-item">
                        <label>Người lớn</label>
                        <span>@Model.NumAdults người</span>
                    </div>
                    <div class="dg-item">
                        <label>Trẻ em</label>
                        <span>@Model.NumChildren em</span>
                    </div>
                </div>
            </div>

            <!-- Phòng đã đặt -->
            <div class="bd-card">
                <div class="bd-card-title">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M2 9V6a2 2 0 012-2h16a2 2 0 012 2v3" />
                        <path d="M2 11h20v9a2 2 0 01-2 2H4a2 2 0 01-2-2v-9z" />
                        <path d="M7 11v4M17 11v4" />
                    </svg>
                    Phòng đã đặt
                </div>
                @foreach (var br in Model.BookingRooms)
                {
                    <div class="room-item">
                        <div class="room-item-name">@br.RoomType?.Name</div>
                        <div class="room-item-price">
                            @br.PricePerNight.ToString("N0")đ/đêm × @Model.TotalNights đêm
                            = <strong>@br.TotalPrice.ToString("N0")đ</strong>
                        </div>
                    </div>
                }
            </div>

            <!-- Dịch vụ thêm -->
            <div class="bd-card">
                <div class="bd-card-title">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                    </svg>
                    Dịch vụ thêm
                </div>
                @if (Model.BookingServices.Any())
                {
                    foreach (var bs in Model.BookingServices)
                    {
                        <div class="service-item">
                            <span>@bs.Service?.Name × @bs.Quantity</span>
                            <strong>@bs.TotalPrice.ToString("N0")đ</strong>
                        </div>
                    }
                }
                else
                {
                    <p class="empty-services">Không có dịch vụ thêm</p>
                }
            </div>
        </div>

        <!-- Thanh toán — full width -->
        <div class="bd-card payment" style="margin-bottom:1.25rem;">
            <div class="bd-card-title">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="5" width="20" height="14" rx="2" />
                    <path d="M2 10h20" />
                </svg>
                Thanh toán
            </div>
            <div class="sum-row">
                <span>Tiền phòng</span>
                <span>@Model.SubTotal.ToString("N0")đ</span>
            </div>
            @if (Model.ServiceTotal > 0)
            {
                <div class="sum-row">
                    <span>Dịch vụ</span>
                    <span>@Model.ServiceTotal.ToString("N0")đ</span>
                </div>
            }
            <div class="sum-row total">
                <span>Tổng cộng</span>
                <span>@Model.TotalAmount.ToString("N0")đ</span>
            </div>
            <div class="sum-row">
                <span>Đặt cọc</span>
                <span>@Model.DepositAmount.ToString("N0")đ</span>
            </div>
            <div class="sum-row paid">
                <span>Đã thanh toán</span>
                <span>@Model.PaidAmount.ToString("N0")đ</span>
            </div>
            <div class="sum-row remain">
                <span>Còn lại</span>
                <span>@remaining.ToString("N0")đ</span>
            </div>
        </div>

        <!-- Yêu cầu đặc biệt -->
        @if (!string.IsNullOrEmpty(Model.SpecialRequest))
        {
            <div class="bd-card special" style="margin-bottom:1.25rem;">
                <div class="bd-card-title">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" />
                        <polyline points="14 2 14 8 20 8" />
                        <line x1="16" y1="13" x2="8" y2="13" />
                        <line x1="16" y1="17" x2="8" y2="17" />
                        <polyline points="10 9 9 9 8 9" />
                    </svg>
                    Yêu cầu đặc biệt
                </div>
                <p>@Model.SpecialRequest</p>
            </div>
        }

        <!-- Actions -->
        <div class="bkdetail-actions">
            @if (Model.Status == BookingStatus.Completed && Model.Review == null)
            {
                <a asp-action="WriteReview" asp-route-id="@Model.Id" class="btn-review-action">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                    </svg>
                    Viết đánh giá
                </a>
            }
            @if (Model.Status == BookingStatus.Pending || Model.Status == BookingStatus.Confirmed)
            {
                <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" style="display:inline"
                      onsubmit="return confirm('Xác nhận hủy booking này?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-cancel-action">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10" />
                            <path d="M15 9l-6 6M9 9l6 6" />
                        </svg>
                        Hủy booking
                    </button>
                </form>
            }
            @if (Model.Review != null)
            {
                <span class="badge-reviewed">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12" />
                    </svg>
                    Đã đánh giá @Model.Review.Rating sao
                </span>
            }
        </div>

    </div>
</div>
