@model ResortBookingMVC.Models.Booking
@{
    ViewData["Title"] = "Đặt phòng thành công";
}

@section Styles {
    <link rel="stylesheet" href="~/css/booking-success.css" asp-append-version="true" />
}

<div class="success-page">
    <div class="success-inner">

        <!-- LEFT -->
        <div class="success-left">
            <div class="success-resort-name">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
                    <polyline points="9 22 9 12 15 12 15 22" />
                </svg>
                @Model.Resort?.Name
            </div>

            <h1>Đặt phòng<br>thành công!</h1>

            <p>Cảm ơn bạn đã đặt phòng. Chúng tôi sẽ xác nhận booking trong vòng 24 giờ qua email.</p>

            <div class="booking-code-wrap">
                <span class="booking-code-label">Mã booking</span>
                <span class="booking-code-val">#@Model.BookingCode</span>
            </div>

            <div class="success-actions">
                <a asp-action="Detail" asp-route-id="@Model.Id" class="btn-primary-success">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                        <circle cx="12" cy="12" r="3" />
                    </svg>
                    Xem chi tiết booking
                </a>
                <a asp-action="MyBookings" class="btn-ghost-success">
                    Tất cả booking
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14M12 5l7 7-7 7" />
                    </svg>
                </a>
            </div>
        </div>

        <!-- RIGHT -->
        <div class="success-right">
            <div class="detail-card">

                <div class="detail-card-top">
                    <div class="detail-amount">@Model.DepositAmount.ToString("N0")đ</div>
                    <div class="detail-amount-label">Cần thanh toán ngay</div>
                    <div class="detail-status-badge">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2.5"
                             stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10" />
                            <polyline points="12 6 12 12 16 14" />
                        </svg>
                        Chờ xác nhận
                    </div>
                </div>

                <div class="detail-rows">
                    <div class="detail-section-title">Chi tiết đặt phòng</div>

                    <div class="detail-row">
                        <span>Địa điểm</span>
                        <span>@Model.Resort?.Location?.Province</span>
                    </div>
                    <div class="detail-row">
                        <span>Nhận phòng</span>
                        <span>@Model.CheckInDate.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="detail-row">
                        <span>Trả phòng</span>
                        <span>@Model.CheckOutDate.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="detail-row">
                        <span>Số đêm</span>
                        <span>@Model.TotalNights đêm</span>
                    </div>
                    <div class="detail-row">
                        <span>Số phòng</span>
                        <span>@Model.NumRooms phòng</span>
                    </div>

                    <div class="detail-divider"></div>

                    <div class="detail-row detail-row-total">
                        <span>Tổng tiền</span>
                        <span>@Model.TotalAmount.ToString("N0")đ</span>
                    </div>
                    <div class="detail-row detail-row-deposit">
                        <span>Thanh toán ngay</span>
                        <span>@Model.DepositAmount.ToString("N0")đ</span>
                    </div>
                </div>

            </div>
        </div>

    </div>
</div>
