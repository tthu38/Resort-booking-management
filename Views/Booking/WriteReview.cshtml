@model ResortBookingMVC.Models.Review
@{
    ViewData["Title"] = "Viết đánh giá";
    var booking = ViewBag.Booking as ResortBookingMVC.Models.Booking;
}

<div class="container" style="max-width:580px;padding:40px 20px;">
    <h1 class="page-title">⭐ Đánh giá resort</h1>

    @if (booking != null)
    {
        <div class="form-card" style="background:#eff6ff;margin-bottom:20px;">
            <strong>@booking.Resort?.Name</strong>
            <p style="font-size:.9rem;color:#64748b;margin-top:4px;">
                @booking.CheckInDate.ToString("dd/MM/yyyy") → @booking.CheckOutDate.ToString("dd/MM/yyyy")
                · @booking.TotalNights đêm
            </p>
        </div>
    }

    <div class="auth-card" style="max-width:100%">
        <form asp-action="WriteReview" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="BookingId" />
            <input type="hidden" asp-for="ResortId" />

            <div class="form-group">
                <label style="font-size:1rem;font-weight:700;">Đánh giá của bạn *</label>
                <div class="star-picker" style="display:flex;gap:8px;margin-top:8px;">
                    @for (int s = 1; s <= 5; s++)
                    {
                        <label style="cursor:pointer;font-size:2rem;color:#d1d5db;" class="star-label">
                            <input type="radio" asp-for="Rating" value="@s" style="display:none;" required />
                            ★
                        </label>
                    }
                </div>
            </div>

            <div class="form-group">
                <label>Nhận xét của bạn</label>
                <textarea asp-for="Comment" class="form-control" rows="5"
                          placeholder="Chia sẻ trải nghiệm của bạn về resort, dịch vụ, phòng ốc..."></textarea>
            </div>

            <div style="display:flex;gap:12px;">
                <button type="submit" class="btn btn-primary">📤 Gửi đánh giá</button>
                <a asp-action="Detail" asp-route-id="@Model.BookingId" class="btn btn-outline">← Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
// Star picker highlight
document.querySelectorAll('.star-label').forEach((label, idx, all) => {
    label.addEventListener('mouseover', () => {
        all.forEach((l, i) => l.style.color = i <= idx ? '#f59e0b' : '#d1d5db');
    });
    label.addEventListener('click', () => {
        label.querySelector('input').checked = true;
        all.forEach((l, i) => l.style.color = i <= idx ? '#f59e0b' : '#d1d5db');
    });
});
document.querySelector('.star-picker').addEventListener('mouseleave', () => {
    const checked = document.querySelector('.star-picker input:checked');
    const idx = checked ? parseInt(checked.value) - 1 : -1;
    document.querySelectorAll('.star-label').forEach((l, i) => {
        l.style.color = i <= idx ? '#f59e0b' : '#d1d5db';
    });
});
</script>
}
